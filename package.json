{
  "name": "airi-press",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm gen:wallpapers && cross-env VITE_LOCAL_MODE=true vite",
    "build": "pnpm gen:wallpapers && cross-env VITE_LOCAL_MODE=false vue-tsc -b && vite build",
    "build:gh": "pnpm gen:wallpapers && cross-env VITE_DEPLOY_TARGET=github VITE_ASMR_API_URL=https://api.asmr-200.com vue-tsc -b && vite build --base=/airi-press/ && node -e \"require('fs').copyFileSync('dist/index.html', 'dist/404.html')\"",
    "preview": "vite preview",
    "gen:posts": "tsx scripts/generate-posts.ts",
    "gen:wallpapers": "tsx scripts/generate-wallpapers.ts"
  },
  "dependencies": {
    "@vueuse/core": "^14.1.0",
    "front-matter": "^4.0.2",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.25",
    "lucide-vue-next": "^0.556.0",
    "markdown-it": "^14.1.0",
    "markdown-it-katex": "^2.0.3",
    "pinia": "^3.0.4",
    "vue": "^3.5.24",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "cross-env": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vue-tsc": "^3.1.4"
  }
}
